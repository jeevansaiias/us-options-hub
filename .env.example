# Schwab Developer App credentials
# Sign up free at https://developer.schwab.com/dashboard/apps
# Make sure your app has "Market Data Production" scope enabled.
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=

# Must match your app's "Callback URL" exactly (incl. https + port).
# For local dev with the bundled proxy server:
SCHWAB_REDIRECT_URI=https://127.0.0.1:8443/api/auth/callback

# Proxy server bind port (default 8443 for HTTPS, 8080 for plain HTTP fallback)
PROXY_PORT=8443

# Cache TTL for chain/quote responses (seconds). Schwab quotes refresh fast;
# 5s is a reasonable balance between freshness and rate-limit safety.
CACHE_TTL_SECONDS=5
